{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "verbatimModuleSyntax": false,
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "electron-dist",
    "rootDir": "electron",
    "noEmit": false,
    "sourceMap": true
  },
  "include": ["electron"]
}
